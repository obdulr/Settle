{
  "name": "settle-monorepo",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@9.15.5",
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "start": "pnpm --filter settle-api start:prod",
    "dev": "pnpm --filter settle-web dev",
    "dev:api": "pnpm --filter settle-api start:dev",
    "dev:mobile": "pnpm --filter settle-mobile start",
    "build": "pnpm --filter @settle/shared-sdk build && turbo run build",
    "build:shared-sdk": "pnpm --filter @settle/shared-sdk build",
    "build:shared": "pnpm --filter @settle/shared build",
    "build:web": "pnpm --filter settle-web build",
    "build:api": "pnpm --filter settle-api build",
    "build:mobile": "pnpm --filter settle-mobile build",
    "lint": "eslint . --ext .ts,.tsx,.js,.jsx",
    "lint:fix": "eslint . --ext .ts,.tsx,.js,.jsx --fix",
    "format": "prettier --write \"**/*.{ts,tsx,.js,.jsx,json,md}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,.js,.jsx,json,md}\"",
    "clean:mac-files": "find . -name '._*' -type f -not -path '*/node_modules/*' -not -path '*/.git/*' -not -path '*/.next/*' -delete",
    "configure:macos": "./scripts/configure-macos.sh",
    "install:hooks": "./scripts/install-hooks.sh"
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.6.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "prettier": "^3.9.1",
    "turbo": "^2.0.0",
    "typescript": "^5.0.0"
  }
}
